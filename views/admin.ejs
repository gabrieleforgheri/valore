<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Valore Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <style>
        body { background: #f3f4f6; }
        .drag-handle { cursor: grab; }
        .drag-handle:active { cursor: grabbing; }
    </style>
</head>
<body class="text-gray-800 font-sans antialiased">
    <div id="app" class="min-h-screen pb-12">
        <!-- Navbar -->
        <nav class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-10">
            <div class="max-w-4xl mx-auto px-4 py-4 flex justify-between items-center">
                <div class="flex items-center gap-3">
                    <img :src="'/' + profile.image" class="w-10 h-10 rounded-full object-cover shadow-sm border border-gray-100">
                    <h1 class="text-xl font-bold text-gray-900">Gestione Linktree</h1>
                </div>
                <div class="flex gap-3">
                    <a href="/" target="_blank" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-full transition-colors">Vedi Sito</a>
                    <button @click="save" class="px-4 py-2 text-sm font-semibold text-white bg-black hover:bg-gray-800 rounded-full transition-colors shadow-md flex items-center gap-2">
                        <span v-if="saving">Salvataggio...</span>
                        <span v-else>Salva Modifiche</span>
                    </button>
                </div>
            </div>
        </nav>

        <div class="max-w-4xl mx-auto px-4 mt-8 grid grid-cols-1 md:grid-cols-3 gap-8">
            
            <!-- Left Column: Editor -->
            <div class="md:col-span-2 space-y-6">
                <!-- Profile Section -->
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                    <h2 class="text-lg font-bold mb-4">Profilo</h2>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-600 mb-1">Nome Profilo</label>
                            <input v-model="profile.name" type="text" class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-black">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-600 mb-1">Bio / Descrizione</label>
                            <input v-model="profile.description" type="text" class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-black">
                        </div>
                    </div>
                </div>

                <!-- Links Section -->
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="text-lg font-bold">I tuoi Link</h2>
                        <button @click="addLink" class="px-4 py-2 text-sm font-medium text-white bg-purple-600 hover:bg-purple-700 rounded-full transition-colors shadow-sm">
                            + Aggiungi Link
                        </button>
                    </div>

                    <div class="space-y-4">
                        <div v-for="(link, index) in links" :key="link.id" class="bg-gray-50 p-4 rounded-xl border border-gray-200 flex gap-4 transition-all relative group">
                            
                            <!-- Move buttons -->
                            <div class="flex flex-col justify-center items-center gap-1 text-gray-400">
                                <button @click="moveUp(index)" :disabled="index === 0" class="hover:text-black disabled:opacity-30"><svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path></svg></button>
                                <button @click="moveDown(index)" :disabled="index === links.length - 1" class="hover:text-black disabled:opacity-30"><svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg></button>
                            </div>

                            <!-- Link form -->
                            <div class="flex-1 space-y-3">
                                <div class="flex gap-3">
                                    <div class="flex-1">
                                        <input v-model="link.title" placeholder="Titolo (es. Spotify)" class="w-full px-3 py-1.5 bg-white border border-gray-200 rounded-md text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-purple-500">
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <label class="text-xs text-gray-500 font-medium">In Evidenza?</label>
                                        <input type="checkbox" v-model="link.featured" class="w-4 h-4 text-purple-600 rounded">
                                    </div>
                                    <button @click="removeLink(index)" class="text-gray-400 hover:text-red-500 p-1 transition-colors">
                                        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </div>
                                <div>
                                    <input v-model="link.url" placeholder="URL (es. https://...)" class="w-full px-3 py-1.5 bg-white border border-gray-200 rounded-md text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-purple-500">
                                </div>
                                <div v-if="link.featured">
                                    <input v-model="link.thumbnail" placeholder="URL Immagine (opzionale)" class="w-full px-3 py-1.5 bg-white border border-gray-200 rounded-md text-xs text-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Live Preview -->
            <div class="hidden md:block">
                <div class="sticky top-24 border-[8px] border-black rounded-[3rem] overflow-hidden bg-gray-900 shadow-2xl h-[700px] w-full max-w-[340px] mx-auto flex flex-col relative">
                    <div class="absolute top-0 inset-x-0 h-6 bg-black z-20 flex justify-center rounded-b-xl w-32 mx-auto"></div>
                    <iframe id="preview-frame" src="/" class="w-full h-full border-0 bg-transparent z-10"></iframe>
                </div>
                <p class="text-center text-xs text-gray-500 mt-4">Anteprima dal vivo. Salva per aggiornare.</p>
            </div>
            
        </div>
    </div>

    <script>
        const initialData = <%- JSON.stringify(data) %>;
        
        const { createApp } = Vue;

        createApp({
            data() {
                return {
                    profile: initialData.profile,
                    links: initialData.links,
                    saving: false
                }
            },
            methods: {
                addLink() {
                    this.links.unshift({
                        id: Date.now().toString(),
                        title: 'Nuovo Link',
                        url: 'https://',
                        featured: false,
                        thumbnail: ''
                    });
                },
                removeLink(index) {
                    if(confirm('Sei sicuro di voler eliminare questo link?')) {
                        this.links.splice(index, 1);
                    }
                },
                moveUp(index) {
                    if (index > 0) {
                        const temp = this.links[index];
                        this.links[index] = this.links[index - 1];
                        this.links[index - 1] = temp;
                    }
                },
                moveDown(index) {
                    if (index < this.links.length - 1) {
                        const temp = this.links[index];
                        this.links[index] = this.links[index + 1];
                        this.links[index + 1] = temp;
                    }
                },
                async save() {
                    this.saving = true;
                    try {
                        const res = await fetch('/admin/update', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                profile: this.profile,
                                links: this.links
                            })
                        });
                        if (res.ok) {
                            document.getElementById('preview-frame').src = document.getElementById('preview-frame').src;
                        } else {
                            alert('Errore nel salvataggio');
                        }
                    } catch (e) {
                        alert('Errore di connessione');
                    }
                    this.saving = false;
                }
            }
        }).mount('#app');
    </script>
</body>
</html>
